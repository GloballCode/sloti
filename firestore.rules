rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Usuário autenticado lê/escreve seu próprio doc
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Workspaces: autenticado pode criar e ler
    // Só o owner pode atualizar/deletar
    match /workspaces/{wsId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && request.auth.uid == resource.data.ownerId;
    }

    // Agendamentos: só membros do mesmo workspace
    match /appointments/{apptId} {
      allow read, write: if request.auth != null
        && request.auth.uid != null;
    }
  }
}
